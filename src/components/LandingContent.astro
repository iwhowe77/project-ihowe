---
import euston from '../assets/euston.jpg';
import { Content as LandingMarkdown } from '../content/landing.md';
import { Content as OtherStuffMarkdown } from '../content/other-stuff.md';
import SocialLinks from './SocialLinks.astro';
---
<div class="landing-content">
  <img class="hero-image" src={euston.src} alt="Euston" />
  <SocialLinks />
  <LandingMarkdown />

  <details class="other-stuff">
    <summary>Other Stuff</summary>
    <div class="other-stuff-content">
      <OtherStuffMarkdown />
    </div>
  </details>

  <div class="beeminder-section">
    <h2>if I don't do pushups, I get charged $$</h2>
    <div class="beeminder-wrapper">
      <iframe
        src="https://www.beeminder.com/widget?slug=exercise&username=iwhowe77&countdown=true"
        height="245"
        width="230"
        frameborder="0"
        style="border: none; transform: scale(2); transform-origin: top left; display: block;"
      ></iframe>
    </div>
  </div>
</div>

<style>
  .landing-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #4b5563;
  }

  .hero-image {
    display: block;
    width: 100%;
    max-width: 800px;
    height: auto;
    border-radius: 12px;
    margin: 0 0 1.25rem 0;
    object-fit: cover;
  }

  /* --- Typography --- */

  .landing-content :global(h1) {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #111827;
    margin-bottom: 0.5rem;
    margin-top: 0;
  }

  .landing-content :global(h2) {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1f2937;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .landing-content :global(h3) {
    font-size: 0.95rem;
    font-weight: 600;
    color: #374151;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .landing-content :global(p) {
    margin-bottom: 1rem;
  }

  .landing-content :global(ul),
  .landing-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0.5rem 0 1rem;
  }

  .landing-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .landing-content :global(strong) {
    font-weight: 600;
    color: #374151;
  }

  .landing-content :global(a) {
    color: #3245ff;
    text-decoration: none;
    transition: color 0.15s;
  }

  .landing-content :global(a:hover) {
    color: #bc52ee;
  }

  /* --- Other Stuff accordion --- */

  .other-stuff {
    margin-top: 2.5rem;
    border-top: 1px solid #f3f4f6;
    padding-top: 1.5rem;
  }

  .other-stuff > summary {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #111827;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }

  .other-stuff > summary::after {
    content: '›';
    font-size: 1.4rem;
    color: #9ca3af;
    transition: transform 0.2s;
    display: inline-block;
  }

  .other-stuff[open] > summary::after {
    transform: rotate(90deg);
  }

  .other-stuff > summary::-webkit-details-marker {
    display: none;
  }

  .other-stuff-content {
    padding-top: 0.5rem;
  }

  /* --- Beeminder section --- */

  .beeminder-section {
    margin-top: 2.5rem;
    border-top: 1px solid #f3f4f6;
    padding-top: 1.5rem;
  }

  .beeminder-section h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 1.25rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .beeminder-wrapper {
    overflow: hidden;
    width: 460px;
    height: 490px;
    max-width: 100%;
  }
</style>
